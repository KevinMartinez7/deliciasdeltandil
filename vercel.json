{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/delicias-del-tandil/browser",
  "framework": "angular",
  "functions": {
    "api/contact.ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
